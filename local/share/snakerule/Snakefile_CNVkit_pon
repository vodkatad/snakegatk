include: "conf.sk"

# CLEANME: to python and use keys() rather than file names
rule bed_lengths:
    input: expand(BED_DIR+"/{kit}", kit=CAPTURE.values())
    output:  "kits_lengths.tsv"
    shell:
        """
            for k in {input}; do bawk -v n=$k 'BEGIN{{bp=0}} {{bp=bp+($3-$2)}} END{{print n,bp}}' $k; done > {output}
        """

rule bed_intersect:
    input: expand(BED_DIR+"/{kit}", kit=CAPTURE.values())
    output:  "all_kits_int.bed"
    params: wanted=len(CAPTURE.values())
    shell: 
        """
            multiIntersectBed -i {input} | bawk '$4=={params.wanted}' > {output}
        """
    
rule intersect_length:
    input:  "all_kits_int.bed"
    output:  "kits_intersect_length.tsv"
    shell:
        """
            bawk -v n={input} 'BEGIN{{bp=0}} {{bp=bp+($3-$2)}} END{{print n,bp}}' {input} > {output}
        """

# split larger exons in smaller bins (266.6?) and assign name
#Exons in the human genome have an average size of about 200bp. The target bin size default of 267 is chosen so that splitting larger exons will produce bins with a minimum size of 200. Since bins that contain fewer reads result in a noisier copy number signal, this approach ensures the “noisiness” of the bins produced by splitting larger exons will be no worse than average.
#In practice we see good results with an average of 200–300 reads per bin; we therefore recommend an overall on-target sequencing coverage depth of at least 200x to 300x with a read length of 100bp to justify reducing the average target bin size to 100bp.
rule split:
    input: bed="all_kits_int.bed", refFlat=REFFLAT
    output: "targets.bed"
    shell: 
        """
            cnvkit.py target {input.bed} --annotate {input.refFlat} --split -o {output}
        """
# TODO capire e guardare weight of cnrs:
#For hybrid capture, if your targets are not tiled with uniform density – for example, if your target panel is designed with a subset of targets having twice or half the usual number of tiles for a fixed number of genomic bases – you do not need to do anything in particular to compensate for this as long as you are using a pooled reference. When a test sample’s read depths are normalized to the pooled reference, the log2 ratios will even out. However, the “spread” of those bins in your pooled reference, and the “weight” of the corresponding bins in the test sample’s .cnr file, will be correspondingly higher or lower.

# we want to exclude both blacklisted regions and regions in _any_ of our exomes kits from the antitarget.
# and added also centromeres/telomeres from ucsc gap
rule bed_union:
    input: expand(BED_DIR+"/{kit}", kit=CAPTURE.values())
    output:  "all_kits_union.bed"
    shell: 
        """
            multiIntersectBed -i {input} | bawk '$4>=1' > {output}
        """
    
rule blacklist_exclude:
    input: excl=BLACKLIST, kits="all_kits_union.bed", gap=GAP
    output: "exclude.bed"
    shell:
        """
            multiIntersectBed -i {input} | bawk '$4>=1' > {output}.tmp
            bedtools merge -i <(sort -k1,1 -k2,2n {output}.tmp) > {output}
            rm {output}.tmp
        """

# we do not have spike on so that's fine
#https://www.encodeproject.org/documents/cbaffa9e-2e42-434e-8b88-f04619c57080/@@download/attachment/README.txt
# need to remove strange cmq afterwards, having an antitarget on CMV does not make any sense
rule accessible_mappable:
    input: excl="exclude.bed", ref=REF_DIR+'/GRCh38.d1.vd1.fa', chrs=CHRS
    output: "mappable.bed"
    shell: 
        """
            cnvkit.py access {input.ref} -x {input.excl} -o {output}.tmp
            filter_1col 1 {input.chrs} < {output}.tmp > {output}
            rm {output}.tmp
        """

