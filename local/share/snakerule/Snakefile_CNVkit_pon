# we do not have spike on so that's fine
#https://www.encodeproject.org/documents/cbaffa9e-2e42-434e-8b88-f04619c57080/@@download/attachment/README.txt
rule accessible_mappable:
    input: excl=BLACKLIST, ref=REF_DIR+'/GRCh38.d1.vd1.fa'
    output: "mappable.bed"
    shell: 
        """
            cnvkit.py access {input.ref} -x {input.excl} -o {output}
        """

rule antitarget:
    input: targ="targets.bed", mappable="mappable.bed"
    output: antitarg="antitargets.bed"
    shell:
        """
            cnvkit.py antitarget {input.targ} -g {input.mappable} -o {output}
        """

