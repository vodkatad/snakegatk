rule a_target_coverage:
    input: bam=BAM_DIR+"/realigned_{sample}.bam", bed="{target}s.bed"
    output: "cnn/{sample}.{target}coverage.cnn"
    log: depth="cnn/{sample}.{target}.cnn.log"
    params: cores=CORES
    benchmark: "bench/{sample}_{target}.times.txt"
    shell: 
        """
            cnvkit.py coverage {input.bam} {input.bed} -o {output} -p {params.cores} 2> {log.depth}
        """

#used mmv and not run after discovering cnvkit naming assumptions, could not work
rule all_coverage:
    input: expand("cnn/{sample}.targetcoverage.cnn", sample=SAMPLES), expand("cnn/{sample}.antitargetcoverage.cnn", sample=SAMPLES) 

# then
#cnvkit.py reference *coverage.cnn -f ucsc.hg19.fa -o Reference.cnn
rule ref:
    input: targ=expand("cnn/{sample}.targetcoverage.cnn", sample=SAMPLES), atarg=expand("cnn/{sample}.antitargetcoverage.cnn", sample=SAMPLES), ref=REF_DIR+'/GRCh38.d1.vd1.fa'
    output: "Reference.cnn"
    benchmark: "bench/Reference.cnn.times.txt"
    shell:  
        """
            cnvkit.py reference cnn -f {input.ref} -o {output}
        """

# fix segment call then to call CN on tumor samples -> cnr
rule cnr:
    input: targ="cnn/{sample}.targetcoverage.cnn", atarg="cnn/{sample}.antitargetcoverage.cnn", ref="flat_reference.cnn"
    output: "cnr/{sample}.cnr"
    benchmark: "bench/{sample}_cnr.times.txt"
    shell:  
        """
            cnvkit.py fix {input.targ} {input.atarg} {input.ref} -o {output}
        """
# cnr -> cns with segment
rule cns:
    input: "cnr/{sample}.cnr"
    output: "cns/{sample}.cns"
    benchmark: "bench/{sample}_cns.times.txt"
    params: cores=CORES
    shell:  
        """
            cnvkit.py segment -o {output} -p {params.cores} {input}
        """

# then call to integer CN
# scatter produces a plot
# metrics https://cnvkit.readthedocs.io/en/stable/reports.html#metrics
rule all_cns:
    input: expand("cns/{sample}.cns", sample=SAMPLES)

rule all_plot:
    input: expand("{sample}_scatter.png", sample=SAMPLES)

# -v Sample.vcf 
rule plot:
    input: cns="cns/{sample}.cns", cnr="cnr/{sample}.cnr"
    output: "{sample}_scatter.png"
    shell:
        """
            cnvkit.py scatter {input.cnr} -s {input.cns} -o {output}
        """

rule metrics:
    input: cns=expand("cns/{sample}.cns", sample=SAMPLES), cnr=expand("cnr/{sample}.cnr", sample=SAMPLES)
    output:  "metrics.txt"
    shell:
        """
            cnvkit.py metrics {input.cnr} -s {input.cns} -o {output}
        """

rule flat:
    input: ref=REF_DIR+'/GRCh38.d1.vd1.fa', targ='targets.bed', atarg='antitargets.bed'
    output: "flat_reference.cnn"
    shell:
        """
        cnvkit.py reference -o {output} -f {input.ref} -t {input.targ} -a {input.atarg}
        """

