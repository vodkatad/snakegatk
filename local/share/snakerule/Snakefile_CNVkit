rule a_target_coverage:
    input: bam=ALIGN_DIR+"/realigned_{sample}.sorted.bam", bed=CNVKIT+"/{target}s.bed"
    output: "cnvkit/{sample}.{target}coverage.cnn"
    log: depth="cnvkit/{sample}.{target}.cnn.log"
    params: cores=CCORES
    benchmark: "bench/{sample}_{target}.times.txt"
    shell: 
        """
            cnvkit.py coverage {input.bam} {input.bed} -o {output} -p {params.cores} 2> {log.depth}
        """

#used mmv and not run after discovering cnvkit naming assumptions, could not work
rule all_cnvkit_coverage:
    input: expand("cnvkit/{sample}.targetscoverage.cnn", sample=CSAMPLES), expand("cnn/{sample}.antitargetscoverage.cnn", sample=CSAMPLES) 

# fix segment call then to call CN on tumor samples -> cnr
rule cnr:
    input: targ="cnvkit/{sample}.targetcoverage.cnn", atarg="cnvkit/{sample}.antitargetcoverage.cnn", ref=CNVKIT+"/Reference.cnn" 
    output: "cnvkit/{sample}.cnr"
    benchmark: "bench/{sample}_cnr.times.txt"
    shell:  
        """
            cnvkit.py fix {input.targ} {input.atarg} {input.ref} -o {output}
        """
# cnr -> cns with segment
rule cns:
    input: "cnvkit/{sample}.cnr"
    output: "cnvkit/{sample}.cns"
    benchmark: "bench/{sample}_cns.times.txt"
    params: cores=CCORES
    shell:  
        """
            cnvkit.py segment -o {output} -p {params.cores} {input}
        """


# then call to integer CN
# scatter produces a plot

rule all_cns:
    input: expand("cnvkit/{sample}.cns", sample=CSAMPLES)


#  -z, --zygosity-freq [ALT_FREQ]
#                        Ignore VCF's genotypes (GT field) and instead infer zygosity from allele frequencies. [Default if used without a number: 0.2
#  --filter cn will merge adjacent segments with the same resulting CN
#  vcf with germline with our somatic pipeline are simply not there
rule call:
    input:  cns="cnvkit/{sample}.cns"
    output:  "cnvkit/{sample}.cn.tsv"
    shell:  
        """
            cnvkit.py call {input.cns} --purity 1 --ploidy 3 -m clonal --filter cn -o {output}
        """

rule all_call:
    input: expand("cnvkit/{sample}.cn.tsv", sample=CSAMPLES)

# -v Sample.vcf 
rule plot:
    input: cns="cnvkit/{sample}.cns", cnr="cnvkit/{sample}.cnr"
    output: "cnvkit/{sample}_scatter.png"
    shell:
        """
            cnvkit.py scatter {input.cnr} -s {input.cns} -o {output}
        """

rule metrics:
    input: cns=expand("cns/{sample}.cns", sample=CSAMPLES), cnr=expand("cnr/{sample}.cnr", sample=CSAMPLES)
    output:  "metrics.txt"
    shell:
        """
            cnvkit.py metrics {input.cnr} -s {input.cns} -o {output}
        """

# let's assume they are both 1 based close ended right now FIXME
rule cmp:
    input: cnvkit="cnvkit/{sample}.cn.tsv", sequenza="sequenza/{sample}/{sample}_segments.txt", len=CHR_LEN
    output: "cnvkit/{sample}_unionbedg.bed"
    log: log="cnvkit/{sample}_comp.txt", loglen="cnvkit/{sample}_len.txt"
    shell:
        """
            bedtools unionbedg -i <(bawk 'NR!=1{{print $1,$2-1,$3,$6}}' {input.cnvkit}) <(bawk 'NR!=1{{print $1,$2-1,$3,$10}}' {input.sequenza}) -empty -g {input.len} -filler -1 > {output}
            wc -l {input.cnvkit} > {log.log}
            wc -l {input.sequenza}  >> {log.log}
            bawk 'BEGIN{{bp=0}} {{bp=bp+($3-$2)}} END{{print FILENAME,bp}}' {input.cnvkit} > {log.loglen}
            bawk 'BEGIN{{bp=0}} {{bp=bp+($3-$2)}} END{{print FILENAME,bp}}' {input.sequenza} >> {log.loglen}
        """

rule all_cmp:
    input: expand("cnvkit/{sample}_unionbedg.bed", sample=CSAMPLES)
    output: "cnvkit/cmp.tsv"
    shell:
        """
            for f in {input}; do bawk '{{print FILENAME, $0}}' $f; done > {output}
        """

# temporary rule to run when having also sequenza run on matched normal controls, no inputs depends on sequenza having run with metacharacters (WARNING)
rule ploidy:
    output: "cnvkit/ploidy.txt"
    shell: 
        """
            for f in sequenza/*/*_confints_CP.txt; do echo -en "$f\t"; head -n2 $f | tail -n1 | cut -f 3; done |tr "/" "\t"| cut -f 2,4 > {output}
        """

